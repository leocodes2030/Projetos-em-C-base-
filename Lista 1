1.3: A Conta do Restaurante: Problema: Leia o valor total de uma conta de restaurante.
O programa deve calcular os 10% do garçom, somar ao valor original e, em
seguida, perguntar entre quantas pessoas a conta será dividida. Exiba o valor final
que cada pessoa deve pagar.

#include <stdio.h>

int main() {
    float conta, contatx, total, porcent;
    int pessoas;
    
    printf("Qual foi o valor da conta? ");
    scanf("%f", &conta);
    
    porcent = conta * 0.10;
    contatx = conta + porcent;
    
    printf("\nValor da conta: R$ %.2f", conta);
    printf("\n10%% do garçom: R$ %.2f", porcent);
    printf("\nTotal a pagar: R$ %.2f\n\n", contatx);
    
    printf("Quantos vão pagar? ");
    scanf("%d", &pessoas);
    
    total = contatx/pessoas;
    
    if (pessoas > 0) {
        total = contatx / pessoas;
        printf("\nCada um paga: R$ %.2f\n", total);
    } else {
        printf("\nNúmero de pessoas inválido!\n");
    }

    return 0;
}

