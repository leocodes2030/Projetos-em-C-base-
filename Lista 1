1.1: O Termômetro Global: Problema: Leia uma temperatura em graus Celsius e
converta para Fahrenheit. A fórmula da física é: F = C × 9

#include <stdio.h>

int main() {
    float F, C;
    
    printf("Digite um valor em Celsius: ");
    scanf("%f", &C);
    
    F = C * (9.0/5.0) + 32;
    
    printf("\nEsse valor em Fahrenheit é de %f graus", F);

    return 0;
}

